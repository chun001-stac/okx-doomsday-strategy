#!/usr/bin/env python3
"""
持仓报告发送脚本
每两小时通过Feishu发送持仓报告
"""

import ccxt
import configparser
import subprocess
import json
import time
import glob
from datetime import datetime, timedelta
import os
import re

def analyze_daily_performance():
    """分析当日交易绩效"""
    today = datetime.now().strftime("%Y-%m-%d")
    total_trades = 0
    winning_trades = 0
    total_pnl_percent = 0.0
    pnl_entries = []  # 记录每笔盈亏百分比
    open_trades = []  # 记录开仓交易
    
    try:
        # 查找日志文件（按优先级）
        log_files = []
        
        # 1. 最新的current_fixed_*.log文件（按修改时间排序）
        current_logs = glob.glob("logs/current_fixed_*.log")
        if current_logs:
            current_logs.sort(key=os.path.getmtime, reverse=True)
            # 只检查最近24小时内的文件
            for log_file in current_logs:
                if time.time() - os.path.getmtime(log_file) < 86400:  # 24小时
                    log_files.append(log_file)
        
        # 2. 最新的doomsday_fixed日志
        fixed_logs = glob.glob("logs/doomsday_fixed_*.log")
        if fixed_logs:
            # 按修改时间排序，最新的在前
            fixed_logs.sort(key=os.path.getmtime, reverse=True)
            # 只检查最近24小时内的文件
            for log_file in fixed_logs:
                if time.time() - os.path.getmtime(log_file) < 86400:  # 24小时
                    log_files.append(log_file)
        
        # 3. current_strategy.log（主日志）
        if os.path.exists("logs/current_strategy.log"):
            log_files.append("logs/current_strategy.log")
        
        # 4. strategy_*.log文件（循环脚本生成）
        strategy_logs = glob.glob("logs/strategy_*.log")
        if strategy_logs:
            strategy_logs.sort(key=os.path.getmtime, reverse=True)
            # 只检查最近24小时内的文件
            for log_file in strategy_logs:
                if time.time() - os.path.getmtime(log_file) < 86400:  # 24小时
                    log_files.append(log_file)
        
        # 5. 旧的日志文件（兼容性）
        if os.path.exists("logs/current_fixed.log") and "logs/current_fixed.log" not in log_files:
            log_files.append("logs/current_fixed.log")
        
        if os.path.exists("optimized_strategy.log") and "optimized_strategy.log" not in log_files:
            log_files.append("optimized_strategy.log")
        
        for log_file in log_files:
            if not os.path.exists(log_file):
                continue
                
            with open(log_file, 'r') as f:
                lines = f.readlines()
            
            # 查找今日的交易统计（取最新的）
            latest_total_trades = 0
            latest_win_rate = 0.0
            
            for line in lines:
                if today in line and "交易统计" in line:
                    # 解析格式: "交易统计: 1次交易, 胜率: 100.0%"
                    match = re.search(r'交易统计: (\d+)次交易, 胜率: ([\d\.]+)%', line)
                    if match:
                        latest_total_trades = int(match.group(1))
                        latest_win_rate = float(match.group(2))
            
            if latest_total_trades > 0:
                total_trades = latest_total_trades
                winning_trades = int(round(total_trades * latest_win_rate / 100))
                
                # 如果总交易数已知但胜率为0，则没有盈利交易
                if latest_win_rate == 0:
                    winning_trades = 0
            
            # 查找平仓盈亏百分比（包括盈利和亏损）
            for line in lines:
                if today in line and ("平仓盈利:" in line or "平仓亏损:" in line):
                    # 解析格式: "平仓盈利: 1.20%" 或 "平仓亏损: -5.33%"
                    match = re.search(r'平仓(?:盈利|亏损): ([\d\.\-]+)%', line)
                    if match:
                        pnl_percent = float(match.group(1))
                        pnl_entries.append(pnl_percent)
                        total_pnl_percent += pnl_percent
            
            # 查找开仓交易
            for line in lines:
                if today in line and "开仓成功:" in line:
                    open_trades.append(line.strip())
            
            # 如果没有找到交易统计，但找到了平仓记录，则尝试计算
            if total_trades == 0 and len(pnl_entries) > 0:
                total_trades = len(pnl_entries)
                # 简单估计：正值为盈利，负值为亏损
                winning_trades = sum(1 for p in pnl_entries if p > 0)
            
            # 如果既没有平仓记录也没有交易统计，但有开仓记录，则显示开仓次数
            if total_trades == 0 and len(pnl_entries) == 0 and len(open_trades) > 0:
                total_trades = len(open_trades)
                # 开仓交易尚未平仓，无法确定盈亏
                winning_trades = 0
                total_pnl_percent = 0.0
            
            # 如果在这个文件中找到了数据，就停止查找其他文件
            if total_trades > 0 or len(pnl_entries) > 0 or len(open_trades) > 0:
                break
                        
    except Exception as e:
        print(f"分析日志时出错: {e}")
    
    return total_trades, winning_trades, total_pnl_percent

def get_position_report():
    """获取持仓报告"""
    config = configparser.ConfigParser()
    config.read('config.ini')
    
    api_key = config.get('OKX', 'api_key', fallback='')
    api_secret = config.get('OKX', 'api_secret', fallback='')
    api_password = config.get('OKX', 'api_password', fallback='')
    symbol = config.get('Trading', 'symbol', fallback='ETH-USDT-SWAP')
    testnet = config.getboolean('System', 'testnet', fallback=True)
    
    exchange = ccxt.okx({
        'apiKey': api_key,
        'secret': api_secret,
        'password': api_password,
        'enableRateLimit': True,
        'options': {
            'defaultType': 'swap',
            'sandbox': testnet,
        }
    })
    
    report_lines = []
    
    try:
        # 加载市场
        exchange.load_markets()
        
        # 检查余额
        balance = exchange.fetch_balance()
        usdt_total = balance['USDT']['total'] if 'USDT' in balance else 0
        usdt_free = balance['USDT']['free'] if 'USDT' in balance else 0
        
        # 检查持仓
        positions = exchange.fetch_positions([symbol])
        open_positions = [p for p in positions if float(p.get('contracts', 0)) != 0]
        
        # 获取当前价格
        ticker = exchange.fetch_ticker(symbol)
        current_price = ticker['last']
        
        # 分析当日绩效
        total_trades, winning_trades, total_pnl_percent = analyze_daily_performance()
        
        # 生成报告
        report_lines.append("📊 **OKX模拟交易持仓报告**")
        report_lines.append(f"⏰ 时间: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
        report_lines.append(f"📈 交易对: {symbol}")
        report_lines.append("")
        report_lines.append("💰 **账户余额**")
        report_lines.append(f"   USDT总余额: ${usdt_total:.2f}")
        report_lines.append(f"   USDT可用余额: ${usdt_free:.2f}")
        report_lines.append(f"   ETH当前价格: ${current_price:.2f}")
        report_lines.append("")
        
        if open_positions:
            report_lines.append("📊 **持仓情况**")
            total_notional = 0
            total_pnl = 0
            
            for pos in open_positions:
                contracts = float(pos.get('contracts', 0))
                notional = float(pos.get('notional', 0))
                entry_price = float(pos.get('entryPrice', 0))
                pnl = float(pos.get('unrealizedPnl', 0))
                pnl_pct = (pnl / notional * 100) if notional > 0 else 0
                
                total_notional += notional
                total_pnl += pnl
                
                direction = "做多" if pos['side'] == 'long' else "做空"
                report_lines.append(f"   **{direction} {symbol}**")
                report_lines.append(f"     合约数量: {contracts}")
                report_lines.append(f"     持仓价值: ${notional:.2f}")
                report_lines.append(f"     开仓均价: ${entry_price:.2f}")
                report_lines.append(f"     当前价格: ${current_price:.2f}")
                report_lines.append(f"     未实现盈亏: ${pnl:.2f} ({pnl_pct:.2f}%)")
                report_lines.append("")
            
            # 总计
            total_pnl_pct = (total_pnl / total_notional * 100) if total_notional > 0 else 0
            report_lines.append("📈 **持仓总计**")
            report_lines.append(f"   总持仓价值: ${total_notional:.2f}")
            report_lines.append(f"   总未实现盈亏: ${total_pnl:.2f} ({total_pnl_pct:.2f}%)")
            report_lines.append(f"   仓位占比: {(total_notional / usdt_total * 100):.1f}%")
        else:
            report_lines.append("✅ **无未平仓持仓**")
        
        # 添加每日绩效统计
        report_lines.append("")
        report_lines.append("📅 **今日绩效统计**")
        if total_trades > 0:
            win_rate = (winning_trades / total_trades * 100) if total_trades > 0 else 0
            
            # 检查是否只有开仓交易（没有平仓记录）
            has_closed_trades = total_pnl_percent != 0 or winning_trades > 0
            
            if has_closed_trades:
                report_lines.append(f"   交易次数: {total_trades}次")
                report_lines.append(f"   盈利次数: {winning_trades}次")
                report_lines.append(f"   胜率: {win_rate:.1f}%")
                report_lines.append(f"   累计盈亏: {total_pnl_percent:+.2f}%")
                
                # 估算盈亏金额（基于当前账户余额）
                if total_pnl_percent != 0:
                    # 这是一个粗略估计，实际盈亏应该基于每笔交易的本金
                    estimated_pnl_usdt = usdt_total * (total_pnl_percent / 100)
                    report_lines.append(f"   估算盈亏金额: ${estimated_pnl_usdt:+.2f}")
            else:
                # 只有开仓交易，尚未平仓
                report_lines.append(f"   开仓次数: {total_trades}次")
                report_lines.append(f"   持仓中: {total_trades}次")
                report_lines.append(f"   累计盈亏: 0.00% (尚未平仓)")
        else:
            report_lines.append("   今日尚无交易")
        
        # 检查策略运行状态
        report_lines.append("")
        report_lines.append("⚙️ **策略状态**")
        try:
            # 更精确地检查策略进程
            strategy_running = False
            strategy_pid = None
            
            # 方法1：检查PID文件
            pid_file = "strategy_pid.txt"
            if os.path.exists(pid_file):
                try:
                    with open(pid_file, 'r') as f:
                        pid = int(f.read().strip())
                    # 检查进程是否存在
                    if os.path.exists(f"/proc/{pid}"):
                        # 进一步检查是否确实是策略进程
                        cmdline_file = f"/proc/{pid}/cmdline"
                        if os.path.exists(cmdline_file):
                            with open(cmdline_file, 'r') as f:
                                cmdline = f.read()
                                if "okx_doomsday_fixed.py" in cmdline:
                                    strategy_running = True
                                    strategy_pid = pid
                except:
                    pass
            
            # 方法2：如果PID文件检查失败，使用ps命令
            if not strategy_running:
                ps_output = subprocess.check_output(["ps", "aux"]).decode()
                for line in ps_output.split('\n'):
                    if "okx_doomsday_fixed.py" in line and "grep" not in line and "/usr/bin/bash -c" not in line:
                        # 提取PID
                        parts = line.split()
                        if len(parts) > 1:
                            try:
                                pid = int(parts[1])
                                strategy_running = True
                                strategy_pid = pid
                                break
                            except:
                                continue
            
            if strategy_running:
                report_lines.append(f"   🟢 策略正在运行 (PID: {strategy_pid})")
                
                # 检查最新的日志文件（按优先级）
                log_files_to_check = []
                
                # 1. 最新的current_fixed_*.log文件
                current_logs = glob.glob("logs/current_fixed_*.log")
                if current_logs:
                    current_logs.sort(key=os.path.getmtime, reverse=True)
                    log_files_to_check.extend(current_logs[:2])  # 检查最新的2个
                
                # 2. strategy_*.log（循环脚本生成）
                strategy_logs = glob.glob("logs/strategy_*.log")
                if strategy_logs:
                    strategy_logs.sort(key=os.path.getmtime, reverse=True)
                    log_files_to_check.extend(strategy_logs[:1])  # 检查最新的1个
                
                # 3. doomsday_fixed_*.log文件
                fixed_logs = glob.glob("logs/doomsday_fixed_*.log")
                if fixed_logs:
                    fixed_logs.sort(key=os.path.getmtime, reverse=True)
                    log_files_to_check.extend(fixed_logs[:1])  # 只检查最新的一个
                
                # 4. 旧的日志文件（兼容性）
                if os.path.exists("logs/current_fixed.log") and "logs/current_fixed.log" not in log_files_to_check:
                    log_files_to_check.append("logs/current_fixed.log")
                
                if os.path.exists("optimized_strategy.log"):
                    log_files_to_check.append("optimized_strategy.log")
                
                # 查找最近的活动
                recent_activity_found = False
                for log_file in log_files_to_check:
                    if os.path.exists(log_file):
                        try:
                            # 获取文件最后修改时间
                            file_age = time.time() - os.path.getmtime(log_file)
                            # 如果文件超过1小时没更新，跳过
                            if file_age > 3600:
                                continue
                                
                            with open(log_file, 'r') as f:
                                lines = f.readlines()[-20:]  # 最后20行
                                if not lines:
                                    continue
                                    
                                last_activity = "".join(lines).strip()
                                if last_activity:
                                    # 查找最近的关键活动
                                    recent_lines = []
                                    for line in reversed(lines):
                                        line = line.strip()
                                        if any(keyword in line for keyword in ["信号统计", "交易统计", "平仓", "持仓", "开仓", "收到信号", "动态阈值", "新的一天"]):
                                            # 限制行长度
                                            if len(line) > 100:
                                                line = line[:100] + "..."
                                            recent_lines.append(line)
                                            if len(recent_lines) >= 3:  # 最多显示3行
                                                break
                                    
                                    if recent_lines:
                                        report_lines.append(f"   📝 最近活动 (来自{os.path.basename(log_file)}):")
                                        # 按时间顺序显示（从旧到新）
                                        for line in reversed(recent_lines):
                                            report_lines.append(f"     {line}")
                                        recent_activity_found = True
                                        break
                        except Exception as e:
                            continue
                
                if not recent_activity_found:
                    report_lines.append("   📝 暂无最近活动记录")
                    
            else:
                report_lines.append("   🔴 策略未运行")
        except Exception as e:
            report_lines.append(f"   ⚠️  策略状态检查失败: {str(e)}")
        
        report_lines.append("")
        report_lines.append("🔄 下次报告: 1小时后")
        
    except Exception as e:
        report_lines.append(f"❌ **报告生成失败**")
        report_lines.append(f"   错误: {str(e)}")
    
    return "\n".join(report_lines)

def send_to_feishu(message):
    """通过OpenClaw发送消息到Feishu"""
    try:
        # 用户ID
        user_id = "ou_a371832abcd231155817dbf6d4d5d931"
        
        # 构建命令 - 使用node直接执行openclaw脚本，避免env问题
        cmd = [
            "/root/.nvm/versions/node/v22.22.0/bin/node",
            "/root/.nvm/versions/node/v22.22.0/bin/openclaw", "message", "send",
            "--channel", "feishu",
            "--target", f"user:{user_id}",
            "--message", message
        ]
        
        # 执行命令
        result = subprocess.run(cmd, capture_output=True, text=True)
        
        if result.returncode == 0:
            print("✅ 持仓报告发送成功")
            return True
        else:
            print(f"❌ 发送失败: {result.stderr}")
            return False
            
    except Exception as e:
        print(f"❌ 发送异常: {e}")
        return False

def main():
    """主函数"""
    print(f"📊 生成持仓报告: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
    
    # 生成报告
    report = get_position_report()
    
    # 打印报告（用于调试）
    print(report)
    
    # 发送到Feishu
    print("\n📤 发送报告到Feishu...")
    success = send_to_feishu(report)
    
    if success:
        print("🎉 报告发送完成")
    else:
        print("⚠️  报告发送失败，请检查配置")

if __name__ == "__main__":
    main()